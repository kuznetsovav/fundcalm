# Copy to `.env.local` and set values. No quotes; no spaces around `=`.
# Restart the dev server after changing env files (Next.js reads env at startup).
# This app reads OPENAI_API_KEY from `.env.local` / `.env` first so it wins over a stale shell variable.

OPENAI_API_KEY=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Feature flags — default OFF. Set to 1 to enable.
NEXT_PUBLIC_FEATURE_PAYWALL=
